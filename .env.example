# kali-ai runtime environment configuration
# Copy this file to .env and fill in your API keys

# LLM Provider Keys
KIMI_API_KEY=your_kimi_api_key_here
MOONSHOT_API_KEY=your_moonshot_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# OpenClaw Browser Gateway
OPENCLAW_GATEWAY_TOKEN=your_secure_random_token_here

# Local Ollama Host (Optional)
OLLAMA_HOST=http://host.docker.internal:11434

# Safety & Engagement Tunables
AGENT_TURN_TIMEOUT_SECONDS=1800
AGENT_ENGAGEMENT_MAX_HOURS=6
AGENT_MAX_PHASE_ATTEMPTS=3
