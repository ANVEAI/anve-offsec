FROM kali-ai:latest

USER root
RUN python3 -m venv /opt/dashboard-venv && \
    /opt/dashboard-venv/bin/pip install --no-cache-dir --upgrade pip && \
    /opt/dashboard-venv/bin/pip install --no-cache-dir \
    fastapi==0.115.12 \
    uvicorn[standard]==0.34.2 \
    jinja2==3.1.6 \
    python-multipart==0.0.20 \
    pydantic==2.11.4 \
    aiofiles==24.1.0

USER pentest
WORKDIR /dashboard

EXPOSE 8000

CMD ["/opt/dashboard-venv/bin/python", "/dashboard/app.py"]
